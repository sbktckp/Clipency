{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/login",
      "destination": "/auth/login"
    },
    {
      "source": "/signup",
      "destination": "/auth/signup"
    },
    {
      "source": "/dashboard",
      "destination": "/auth/profile"
    },
    {
      "source": "/campaigns",
      "destination": "/auth/profile"
    },
    {
      "source": "/profile",
      "destination": "/auth/profile"
    },
    {
      "source": "/stats",
      "destination": "/auth/profile"
    },
    {
      "source": "/payouts",
      "destination": "/auth/profile"
    },
    {
      "source": "/wallet",
      "destination": "/auth/profile"
    },
    {
      "source": "/workspace",
      "destination": "/auth/workspace"
    },
    {
      "source": "/accounts",
      "destination": "/auth/accounts"
    },
    {
      "source": "/admin",
      "destination": "/auth/admin"
    },
    {
      "source": "/admin/:file+",
      "destination": "/auth/admin/:file+"
    },
    {
      "source": "/review",
      "destination": "/auth/review"
    },
    {
      "source": "/clipency-admin-os.js",
      "destination": "/auth/clipency-admin-os.js"
    },
    {
      "source": "/clipency-profile-supabase.js",
      "destination": "/auth/clipency-profile-supabase.js"
    },
    {
      "source": "/clipency-account-connect.js",
      "destination": "/auth/clipency-account-connect.js"
    },
    {
      "source": "/clipency-clip-submit.js",
      "destination": "/auth/clipency-clip-submit.js"
    },
    {
      "source": "/clipency-wallet.js",
      "destination": "/auth/clipency-wallet.js"
    },
    {
      "source": "/clipency-:rest*",
      "destination": "/auth/clipency-:rest*"
    },
    {
      "source": "/supabaseClient.js",
      "destination": "/auth/supabaseClient.js"
    },
    {
      "source": "/access-control.js",
      "destination": "/auth/access-control.js"
    },
    {
      "source": "/role-router.js",
      "destination": "/auth/role-router.js"
    },
    {
      "source": "/experience.js",
      "destination": "/auth/experience.js"
    },
    {
      "source": "/app.js",
      "destination": "/auth/app.js"
    },
    {
      "source": "/styles.css",
      "destination": "/auth/styles.css"
    },
    {
      "source": "/assets/:file*",
      "destination": "/auth/assets/:file*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://*.supabase.co https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.frankfurter.app https://cdn.jsdelivr.net https://www.google-analytics.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
        }
      ]
    },
    {
      "source": "/(.*).(png|jpg|jpeg|webp|svg|ico|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}