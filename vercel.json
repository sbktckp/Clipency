{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/login",     "destination": "/Clipency Authentication/login/index.html" },
    { "source": "/signup",    "destination": "/Clipency Authentication/signup/index.html" },
    { "source": "/workspace", "destination": "/Clipency Authentication/workspace/index.html" },
    { "source": "/campaigns", "destination": "/Clipency Authentication/campaigns/index.html" },
    { "source": "/profile",   "destination": "/Clipency Authentication/profile/index.html" },
    { "source": "/accounts",  "destination": "/Clipency Authentication/accounts/index.html" },
    { "source": "/payouts",   "destination": "/Clipency Authentication/payouts/index.html" },
    { "source": "/admin",     "destination": "/Clipency Authentication/admin/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Cross-Origin-Opener-Policy","value": "same-origin-allow-popups" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, s-maxage=0, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, s-maxage=0, must-revalidate" }]
    },
    {
      "source": "/(.*).(js|css)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*).(png|jpg|jpeg|webp|svg|ico|woff|woff2)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
