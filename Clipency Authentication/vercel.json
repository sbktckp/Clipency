{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "destination": "/campaigns",
      "permanent": false
    },
    {
      "source": "/dashboard.html",
      "destination": "/campaigns",
      "permanent": false
    },
    {
      "source": "/login.html",
      "destination": "/login",
      "permanent": true
    },
    {
      "source": "/signup.html",
      "destination": "/signup",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/auth.html"
    },
    {
      "source": "/signup",
      "destination": "/auth.html"
    },
    {
      "source": "/campaigns",
      "destination": "/dashboard.html"
    },
    {
      "source": "/stats",
      "destination": "/dashboard.html"
    },
    {
      "source": "/payouts",
      "destination": "/dashboard.html"
    },
    {
      "source": "/wallet",
      "destination": "/dashboard.html"
    },
    {
      "source": "/profile",
      "destination": "/dashboard.html"
    },
    {
      "source": "/workspace",
      "destination": "/dashboard.html"
    },
    {
      "source": "/admin",
      "destination": "/dashboard.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/dashboard.html"
    },
    {
      "source": "/review",
      "destination": "/dashboard.html"
    }
  ]
}
