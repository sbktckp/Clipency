.header-profile,
.profile-chip {
  border-radius: 18px !important;
}

/* Sidebar scale */
.sidebar,
aside {
  width: 280px !important;
}

.nav-item {
  min-height: 48px !important;
  border-radius: 15px !important;
  margin-bottom: 7px !important;
  font-size: 15px !important;
}

.nav-icon {
  transform: scale(0.92);
}

/* Bottom identity */
.sidebar-user,
.user-footer,
[class*="footer-user"] {
  padding: 14px !important;
}

/* Remove accidental extra huge command center block spacing */
#section-dashboard > .dashboard-hero + *,
#section-dashboard .master-dashboard-shell {
  margin-top: 0 !important;
}

/* Elegant page breathing */
.section {
  padding-bottom: 40px !important;
}

/* Better desktop density */
@media (min-width: 1280px) {
  .campaigns-grid,
  .campaign-grid,
  #campaigns-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  }
}

/* Tablet */
@media (max-width: 1180px) {
  .master-welcome,
  .master-guidance-grid,
  .dashboard-split,
  .premium-profile-hero,
  .premium-profile-grid {
    grid-template-columns: 1fr !important;
  }

  .overview-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  }

  .master-side-card {
    align-self: stretch !important;
  }
}

/* Mobile */
@media (max-width: 720px) {
  :root {
    --content-pad-x: 16px;
    --content-pad-y: 18px;
  }

  .main-content,
  .dashboard-main,
  main,
  .content {
    padding: 72px 16px 24px !important;
  }

  .master-welcome {
    padding: 22px !important;
    border-radius: 24px !important;
  }

  .master-welcome h1 {
    font-size: 38px !important;
    letter-spacing: -0.065em !important;
  }

  .master-helper {
    font-size: 14px !important;
  }

  .overview-grid {
    grid-template-columns: 1fr !important;
  }

  .campaign-card {
    min-height: 220px !important;
  }

  .premium-profile-hero {
    padding: 22px !important;
  }

  .premium-avatar-xl {
    width: 76px !important;
    height: 76px !important;
    font-size: 32px !important;
  }
}
