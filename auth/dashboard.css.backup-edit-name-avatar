  border: 1px solid rgba(255,255,255,0.18);
  box-shadow: 0 22px 60px rgba(124, 58, 237, 0.28);
}

.premium-profile-copy .eyebrow {
  margin-bottom: 10px;
}

.premium-profile-copy h1 {
  margin: 0;
  font-size: clamp(34px, 4vw, 58px);
  letter-spacing: -0.06em;
  line-height: 0.95;
}

.premium-profile-copy p {
  margin: 12px 0 0;
  color: rgba(255,255,255,0.62);
  font-size: 16px;
}

.premium-profile-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

.premium-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border-radius: 999px;
  padding: 10px 14px;
  font-size: 13px;
  font-weight: 850;
  color: #d8ccff;
  border: 1px solid rgba(167, 139, 250, 0.24);
