:root {
  --bg: #07050e;
  --nav: rgba(8, 6, 16, 0.82);
  --surface: rgba(24, 19, 45, 0.72);
  --surface-strong: rgba(31, 24, 58, 0.92);
  --border: rgba(167, 139, 250, 0.18);
  --border-strong: rgba(167, 139, 250, 0.36);
  --text: rgba(255, 255, 255, 0.96);
  --muted: rgba(255, 255, 255, 0.62);
  --faint: rgba(255, 255, 255, 0.38);
  --violet: #7c3aed;
  --violet-soft: #a78bfa;
  --teal: #14b8a6;
  --green: #22c55e;
  --danger: #ef4444;
  --radius: 28px;
  --shadow: 0 28px 90px rgba(0, 0, 0, 0.35);
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-height: 100vh;
  color: var(--text);
  cursor: none;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background:
    radial-gradient(circle at 10% -10%, rgba(124, 58, 237, 0.28), transparent 30%),
    radial-gradient(circle at 90% 0%, rgba(20, 184, 166, 0.12), transparent 26%),
    linear-gradient(180deg, #090713 0%, #07050e 100%);
  -webkit-font-smoothing: antialiased;
  text-rendering: geometricPrecision;
  overflow-x: hidden;
}

a,
button,
input,
select,
textarea {
  cursor: none;
}

a {
  color: inherit;
  text-decoration: none;
}

.scroll-progress {
  position: fixed;
  top: 0;
  left: 0;
  width: 0%;
  height: 3px;
  z-index: 1000000;
  background: linear-gradient(90deg, var(--teal), var(--violet), var(--violet-soft));
  box-shadow: 0 0 22px rgba(167, 139, 250, 0.75);
}

.cursor-dot,
.cursor-ring {
  position: fixed;
  top: 0;
  left: 0;
  pointer-events: none;
  z-index: 999999;
  opacity: 0;
  transform: translate(-50%, -50%);
}

.cursor-dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: #ffffff;
  box-shadow: 0 0 20px rgba(167, 139, 250, 0.9);
}

.cursor-ring {
  width: 38px;
  height: 38px;
  border-radius: 999px;
  border: 1px solid rgba(167, 139, 250, 0.58);
  background: rgba(167, 139, 250, 0.055);
  backdrop-filter: blur(3px);
  transition: width 160ms ease, height 160ms ease, border-color 160ms ease, background 160ms ease;
}

body.cursor-ready .cursor-dot,
body.cursor-ready .cursor-ring {
  opacity: 1;
}

body.cursor-hover .cursor-ring {
  width: 60px;
  height: 60px;
  border-color: rgba(20, 184, 166, 0.72);
  background: rgba(167, 139, 250, 0.12);
}

.page-noise {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  opacity: 0.24;
  background-image:
    linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
  background-size: 54px 54px;
  mask-image: radial-gradient(circle at center, black, transparent 78%);
}

.ambient {
  position: fixed;
  pointer-events: none;
  z-index: 0;
  filter: blur(80px);
  opacity: 0.45;
}

.ambient-one {
  width: 360px;
  height: 360px;
  left: -120px;
  top: 120px;
  background: rgba(124, 58, 237, 0.35);
}

.ambient-two {
  width: 420px;
  height: 420px;
  right: -160px;
  top: 360px;
  background: rgba(20, 184, 166, 0.16);
}

.landing-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  min-height: 76px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 28px;
  padding: 14px clamp(28px, 5vw, 88px);
  background: var(--nav);
  border-bottom: 1px solid rgba(255,255,255,0.075);
  backdrop-filter: blur(24px);
  box-shadow: 0 12px 44px rgba(0,0,0,0.18);
}

.brand-lockup {
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  width: auto;
  min-width: 0;
  height: auto;
  overflow: visible;
}

.clipency-brand-logo {
  display: block;
  width: 112px;
  max-height: 42px;
  height: auto;
  object-fit: contain;
  background: transparent;
  box-shadow: none;
  border-radius: 0;
  opacity: 0.96;
  mix-blend-mode: screen;
}

.nav-links {
  justify-self: center;
  display: flex;
  gap: 28px;
  color: var(--muted);
  font-size: 14px;
  font-weight: 760;
}

.nav-links a {
  position: relative;
  transition: color 180ms ease;
}

.nav-links a::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -8px;
  height: 2px;
  border-radius: 999px;
  transform: scaleX(0);
  transform-origin: left;
  background: linear-gradient(90deg, var(--violet), var(--violet-soft));
  transition: transform 180ms ease;
}

.nav-links a:hover,
.nav-links a.active {
  color: white;
}

.nav-links a:hover::after,
.nav-links a.active::after {
  transform: scaleX(1);
}

.auth-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.nav-login,
.nav-signup {
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 18px;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 900;
}

.nav-login {
  color: var(--muted);
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.025);
}

.nav-signup {
  color: white;
  background: linear-gradient(135deg, var(--violet), var(--violet-soft));
  box-shadow: 0 16px 42px rgba(124,58,237,0.28);
}

main,
.landing-footer {
  position: relative;
  z-index: 1;
}

.hero-section {
  position: relative;
  min-height: calc(100vh - 76px);
  display: grid;
  grid-template-columns: minmax(0, 0.94fr) minmax(360px, 0.72fr);
  gap: clamp(34px, 5vw, 72px);
  align-items: center;
  padding: clamp(56px, 6vw, 84px) clamp(28px, 5vw, 88px) clamp(64px, 7vw, 96px);
}

.hero-section::before {
  content: "";
  position: absolute;
  top: 28px;
  bottom: 28px;
  left: clamp(28px, 5vw, 88px);
  right: clamp(28px, 5vw, 88px);
  border-radius: 38px;
  border: 1px solid rgba(167,139,250,0.08);
  background:
    radial-gradient(circle at 10% 18%, rgba(124,58,237,0.18), transparent 34%),
    radial-gradient(circle at 92% 18%, rgba(20,184,166,0.10), transparent 32%);
  pointer-events: none;
  mask-image: linear-gradient(to bottom, black, transparent 92%);
}

.status-pill {
  width: max-content;
  max-width: 100%;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
  padding: 10px 13px;
  border-radius: 999px;
  color: rgba(255,255,255,0.76);
  background: rgba(255,255,255,0.055);
  border: 1px solid rgba(167,139,250,0.18);
  font-size: 13px;
  font-weight: 850;
}

.status-pill span {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--green);
  box-shadow: 0 0 18px rgba(34,197,94,0.75);
}

.hero-copy h1 {
  max-width: 850px;
  margin: 0 0 22px;
  font-size: clamp(58px, 6.2vw, 98px);
  line-height: 0.91;
  letter-spacing: -0.078em;
  text-wrap: balance;
}

.hero-copy h1::after {
  content: "";
  display: block;
  width: 96px;
  height: 4px;
  margin-top: 24px;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--teal), var(--violet), var(--violet-soft));
  box-shadow: 0 0 32px rgba(167,139,250,0.52);
}

.hero-lede {
  max-width: 710px;
  color: rgba(255,255,255,0.64);
  font-size: clamp(16px, 1.25vw, 19px);
  line-height: 1.68;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 28px;
}

.primary-btn,
.secondary-btn {
  min-height: 50px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 20px;
  border-radius: 16px;
  font-weight: 950;
  font-size: 14px;
  transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
}

.primary-btn {
  color: white;
  background: linear-gradient(135deg, var(--violet), var(--violet-soft));
  box-shadow: 0 20px 56px rgba(124,58,237,0.30);
}

.secondary-btn {
  color: rgba(255,255,255,0.82);
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.055);
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0,1fr));
  gap: 10px;
  max-width: 830px;
  margin-top: 34px;
}

.metric-tile {
  padding: 14px;
  border-radius: 18px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.045);
}

.metric-tile strong {
  display: block;
  margin-bottom: 6px;
  color: white;
  font-size: 25px;
  letter-spacing: -0.04em;
}

.metric-tile span {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.45;
}

.hero-product {
  position: relative;
  min-height: 460px;
}

.glass-panel,
.system-card,
.comparison-panel,
.creator-console,
.insight-card,
.testimonial-card,
.team-card,
.contact-form {
  border: 1px solid var(--border);
  background:
    radial-gradient(circle at top left, rgba(124,58,237,0.16), transparent 34%),
    rgba(255,255,255,0.045);
  box-shadow: 0 22px 70px rgba(0,0,0,0.22);
  backdrop-filter: blur(20px);
}

.product-panel {
  position: absolute;
  inset: 32px 8px auto 0;
  overflow: hidden;
  border-radius: 28px;
  transform: perspective(1000px) rotateY(-3deg) rotateX(2deg);
  transition: transform 420ms cubic-bezier(.2,.8,.2,1), border-color 220ms ease;
}

.product-panel:hover {
  transform: perspective(1000px) rotateY(0deg) rotateX(0deg) translateY(-4px);
  border-color: rgba(167,139,250,0.36);
}

.panel-top {
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.window-dots {
  display: flex;
  gap: 8px;
}

.window-dots span {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: rgba(255,255,255,0.22);
}

.live-badge {
  padding: 8px 11px;
  border-radius: 999px;
  color: var(--green);
  background: rgba(34,197,94,0.12);
  border: 1px solid rgba(34,197,94,0.20);
  font-size: 12px;
  font-weight: 950;
}

.campaign-preview {
  display: grid;
  grid-template-columns: 1fr 150px;
  gap: 22px;
  align-items: center;
  padding: 24px;
}

.panel-kicker,
.eyebrow,
.department-title {
  color: var(--violet-soft);
  font-size: 11px;
  font-weight: 950;
  letter-spacing: 0.20em;
  text-transform: uppercase;
}

.campaign-preview h2 {
  margin: 10px 0 10px;
  font-size: 34px;
  line-height: 0.98;
  letter-spacing: -0.055em;
}

.campaign-preview p {
  margin: 0;
  color: var(--muted);
  line-height: 1.56;
}

.campaign-orbit {
  position: relative;
  width: 132px;
  height: 132px;
  border-radius: 999px;
  border: 1px solid rgba(167,139,250,0.22);
  display: grid;
  place-items: center;
  background: radial-gradient(circle, rgba(124,58,237,0.22), transparent 70%);
}

.orbit-core {
  width: 58px;
  height: 58px;
  display: grid;
  place-items: center;
  border-radius: 20px;
  background: linear-gradient(135deg, var(--teal), var(--violet));
  font-weight: 950;
  font-size: 26px;
}

.orbit-dot {
  position: absolute;
  width: 11px;
  height: 11px;
  border-radius: 999px;
  background: var(--violet-soft);
  box-shadow: 0 0 18px rgba(167,139,250,0.7);
}

.dot-one {
  top: 12px;
  left: 50%;
}

.dot-two {
  right: 12px;
  top: 60%;
}

.dot-three {
  left: 14px;
  bottom: 24px;
}

.workflow-track {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  padding: 0 24px 20px;
}

.workflow-step {
  min-height: 62px;
  display: grid;
  place-items: center;
  gap: 3px;
  border-radius: 17px;
  color: var(--muted);
  font-size: 13px;
  font-weight: 850;
  border: 1px solid rgba(255,255,255,0.09);
  background: rgba(255,255,255,0.045);
}

.workflow-step span {
  color: var(--violet-soft);
  font-size: 11px;
}

.workflow-step.active {
  color: white;
  border-color: rgba(167,139,250,0.36);
  background: rgba(124,58,237,0.14);
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  padding: 0 24px 24px;
}

.product-grid div {
  padding: 15px;
  border-radius: 18px;
  background: rgba(0,0,0,0.18);
  border: 1px solid rgba(255,255,255,0.08);
}

.product-grid span {
  display: block;
  margin-bottom: 7px;
  color: var(--faint);
  font-size: 12px;
}

.product-grid strong {
  font-size: 20px;
  letter-spacing: -0.035em;
}

.floating-card {
  position: absolute;
  padding: 15px 16px;
  border-radius: 18px;
  min-width: 156px;
  border: 1px solid var(--border);
  background: rgba(25, 20, 46, 0.82);
  backdrop-filter: blur(20px);
  box-shadow: var(--shadow);
  animation: floatProof 5.5s ease-in-out infinite;
}

.floating-card span {
  color: var(--violet-soft);
  font-size: 11px;
  font-weight: 950;
  text-transform: uppercase;
  letter-spacing: 0.14em;
}

.floating-card strong {
  display: block;
  margin-top: 8px;
  font-size: 18px;
}

.floating-card-one {
  top: 0;
  right: 0;
}

.floating-card-two {
  bottom: 52px;
  left: -8px;
  animation-delay: 1.3s;
}

@keyframes floatProof {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}

.signal-strip {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 34px;
  overflow: hidden;
  padding: 15px clamp(28px, 5vw, 88px);
  border-top: 1px solid rgba(255,255,255,0.07);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.52);
  font-size: 12px;
  font-weight: 950;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  white-space: nowrap;
  background: rgba(255,255,255,0.025);
  backdrop-filter: blur(14px);
}

.signal-strip span {
  min-width: max-content;
}

.signal-strip span::after {
  content: "•";
  margin-left: 34px;
  color: rgba(167,139,250,0.55);
}

.section {
  padding: clamp(72px, 8vw, 108px) clamp(28px, 5vw, 88px);
}

.section-heading {
  max-width: 880px;
  margin-bottom: 30px;
}

.section-heading.center {
  margin-left: auto;
  margin-right: auto;
  text-align: center;
}

.section h2,
.split-copy h2,
.contact-copy h2 {
  margin: 12px 0 0;
  font-size: clamp(36px, 4.4vw, 64px);
  line-height: 0.98;
  letter-spacing: -0.06em;
  text-wrap: balance;
}

.section-heading p,
.split-copy p,
.contact-copy p {
  color: var(--muted);
  line-height: 1.72;
  font-size: 16px;
}

.system-grid {
  display: grid;
  grid-template-columns: 1.08fr repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.system-card {
  position: relative;
  min-height: 220px;
  padding: 24px;
  border-radius: 24px;
  overflow: hidden;
  transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
}

.system-card.large {
  grid-row: span 2;
  min-height: 460px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.system-card.wide {
  grid-column: span 2;
}

.system-card:hover,
.comparison-panel:hover,
.insight-card:hover,
.testimonial-card:hover,
.team-card:hover,
.contact-form:hover {
  transform: translateY(-4px);
  border-color: var(--border-strong);
  background:
    radial-gradient(circle at top left, rgba(124,58,237,0.20), transparent 34%),
    rgba(255,255,255,0.06);
}

.card-number {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  margin-bottom: 18px;
  border-radius: 16px;
  color: var(--violet-soft);
  background: rgba(167,139,250,0.12);
  font-weight: 950;
}

.system-card h3,
.insight-card h3,
.team-card h3 {
  margin: 0 0 10px;
  font-size: 24px;
  letter-spacing: -0.045em;
}

.system-card p,
.insight-card p,
.team-card p,
.testimonial-card p {
  color: var(--muted);
  line-height: 1.65;
}

.card-line {
  height: 5px;
  width: 130px;
  margin-top: 28px;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--teal), var(--violet-soft));
}

.clients-section,
.contact-section {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(420px, 0.92fr);
  gap: 42px;
  align-items: center;
}

.pill-row,
.contact-points {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 24px;
}

.pill-row span,
.contact-points span {
  padding: 10px 13px;
  border-radius: 999px;
  background: rgba(167,139,250,0.10);
  border: 1px solid rgba(167,139,250,0.20);
  color: #d8ccff;
  font-weight: 850;
  font-size: 13px;
}

.comparison-panel {
  position: relative;
  overflow: hidden;
  padding: 26px;
  border-radius: 24px;
  transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
}

.comparison-panel::before {
  content: "CLIPENCY";
  position: absolute;
  right: -10px;
  bottom: -12px;
  color: rgba(255,255,255,0.035);
  font-size: 72px;
  font-weight: 950;
  letter-spacing: -0.08em;
}

.comparison-row {
  display: grid;
  gap: 8px;
}

.comparison-row span {
  color: var(--violet-soft);
  font-size: 12px;
  font-weight: 950;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.comparison-row strong {
  font-size: clamp(23px, 2.55vw, 34px);
  line-height: 1;
  letter-spacing: -0.055em;
}

.comparison-row.muted strong {
  color: rgba(255,255,255,0.54);
}

.comparison-divider {
  height: 1px;
  margin: 28px 0;
  background: rgba(255,255,255,0.10);
}

.creator-console {
  display: grid;
  grid-template-columns: repeat(4, minmax(0,1fr));
  gap: 1px;
  overflow: hidden;
  border-radius: 24px;
}

.creator-card {
  padding: 26px;
  background: rgba(255,255,255,0.025);
}

.creator-card.active {
  background:
    radial-gradient(circle at top left, rgba(124,58,237,0.20), transparent 40%),
    rgba(255,255,255,0.045);
}

.creator-card span {
  color: var(--violet-soft);
  font-size: 12px;
  font-weight: 950;
}

.creator-card strong {
  display: block;
  margin: 15px 0 10px;
  font-size: 22px;
  letter-spacing: -0.04em;
}

.creator-card p {
  margin: 0;
  color: var(--muted);
  line-height: 1.6;
}

.insight-grid,
.testimonial-grid,
.department-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0,1fr));
  gap: 18px;
}

.insight-card,
.testimonial-card,
.team-card {
  padding: 24px;
  border-radius: 24px;
  transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
}

.insight-card span {
  display: inline-block;
  margin-bottom: 18px;
  color: var(--violet-soft);
  font-size: 12px;
  font-weight: 950;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.testimonial-grid {
  grid-template-columns: 1.2fr 0.9fr 0.9fr;
}

.testimonial-card.featured {
  border-color: rgba(167,139,250,0.28);
  background:
    radial-gradient(circle at top left, rgba(124,58,237,0.22), transparent 34%),
    rgba(255,255,255,0.055);
}

.testimonial-card p {
  font-size: 17px;
}

.testimonial-card div {
  margin-top: 24px;
}

.testimonial-card strong,
.testimonial-card span {
  display: block;
}

.testimonial-card span {
  margin-top: 4px;
  color: var(--faint);
}

.department-block {
  margin-top: 34px;
}

.department-title {
  margin-bottom: 16px;
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0,1fr));
  gap: 18px;
}

.department-grid {
  margin-top: 18px;
}

.team-card.muted {
  opacity: 0.80;
}

.team-avatar {
  width: 62px;
  height: 62px;
  display: grid;
  place-items: center;
  margin-bottom: 18px;
  border-radius: 22px;
  font-size: 27px;
  font-weight: 950;
  background: linear-gradient(135deg, var(--teal), var(--violet));
}

.team-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

.team-links a {
  color: #c4b5fd;
  font-size: 13px;
  font-weight: 900;
}

.contact-section {
  align-items: start;
}

.contact-form {
  padding: 28px;
  border-radius: 24px;
  border-color: rgba(167,139,250,0.28);
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

label {
  display: grid;
  gap: 8px;
  margin-bottom: 14px;
  color: rgba(255,255,255,0.62);
  font-size: 12px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.10em;
}

input,
select,
textarea {
  width: 100%;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 16px;
  background: rgba(0,0,0,0.22);
  color: white;
  padding: 14px 15px;
  font: inherit;
  font-weight: 700;
  outline: none;
}

textarea {
  resize: vertical;
}

input:focus,
select:focus,
textarea:focus {
  border-color: rgba(167,139,250,0.70);
  box-shadow: 0 0 0 4px rgba(124,58,237,0.15);
}

.contact-form button {
  width: 100%;
  min-height: 52px;
  border: none;
  border-radius: 17px;
  background: linear-gradient(135deg, var(--violet), var(--violet-soft));
  color: white;
  font-weight: 950;
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.form-message {
  margin: 14px 0 0;
  color: var(--muted);
  font-size: 14px;
}

.form-message.success {
  color: var(--green);
}

.form-message.error {
  color: var(--danger);
}

.landing-footer {
  display: flex;
  justify-content: space-between;
  gap: 24px;
  padding: 32px clamp(28px, 5vw, 88px);
  border-top: 1px solid rgba(255,255,255,0.07);
  color: var(--muted);
  background:
    radial-gradient(circle at top left, rgba(124,58,237,0.10), transparent 32%),
    rgba(255,255,255,0.025);
}

.footer-brand .clipency-brand-logo,
.footer-logo {
  width: 128px;
  max-height: 48px;
}

.landing-footer p {
  max-width: 480px;
  line-height: 1.6;
}

.footer-socials {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16px;
}

.footer-socials a {
  color: rgba(255,255,255,0.72);
  font-weight: 850;
  transition: color 180ms ease, transform 180ms ease;
}

.footer-socials a:hover {
  color: white;
  transform: translateY(-1px);
}

.reveal {
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 680ms ease, transform 680ms ease;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.delay-1 {
  transition-delay: 90ms;
}

.delay-2 {
  transition-delay: 160ms;
}

.delay-3 {
  transition-delay: 230ms;
}

@media (max-width: 1120px) {
  .hero-section,
  .clients-section,
  .contact-section {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .hero-product {
    min-height: 430px;
  }

  .system-grid,
  .insight-grid,
  .testimonial-grid,
  .department-grid,
  .creator-console {
    grid-template-columns: 1fr 1fr;
  }

  .system-card.large,
  .system-card.wide {
    grid-row: auto;
    grid-column: auto;
    min-height: 240px;
  }

  .nav-links {
    display: none;
  }
}

@media (max-width: 700px) {
  body,
  a,
  button,
  input,
  select,
  textarea {
    cursor: auto;
  }

  .cursor-dot,
  .cursor-ring {
    display: none;
  }

  .landing-nav {
    min-height: 70px;
    grid-template-columns: auto auto;
    padding: 12px 18px;
  }

  .clipency-brand-logo {
    width: 102px;
    max-height: 38px;
  }

  .auth-actions {
    gap: 7px;
  }

  .nav-login,
  .nav-signup {
    min-height: 38px;
    padding: 0 12px;
    font-size: 13px;
  }

  .hero-section {
    padding: 46px 20px 60px;
  }

  .hero-section::before {
    display: none;
  }

  .hero-copy h1 {
    font-size: 48px;
    line-height: 0.94;
  }

  .hero-product {
    display: none;
  }

  .hero-metrics,
  .system-grid,
  .insight-grid,
  .testimonial-grid,
  .department-grid,
  .creator-console,
  .team-grid,
  .form-grid {
    grid-template-columns: 1fr;
  }

  .section {
    padding: 64px 20px;
  }

  .section h2,
  .split-copy h2,
  .contact-copy h2 {
    font-size: 40px;
  }

  .landing-footer {
    flex-direction: column;
    padding: 32px 20px;
  }
}
