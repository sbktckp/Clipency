<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Clipency | Review Clips</title>
  <link rel="stylesheet" href="/staff.css" />
</head>
<body>
  <div class="staff-shell">
    <aside class="staff-sidebar">
      <a class="staff-brand" href="/">
        <img src="/assets/clipency-logo.png" alt="Clipency" />
      </a>

      <nav class="staff-nav">
        <a class="active" href="/review">Review Queue</a>
        <a href="/dashboard">Creator View</a>
        <a href="/login" id="logout-link">Logout</a>
      </nav>
    </aside>

    <main class="staff-main">
      <header class="staff-topbar">
        <div>
          <div class="eyebrow">CLIP REVIEW</div>
          <h1>Review submitted clips.</h1>
          <p>Open proof links, enter performance metrics, approve or reject submissions and add review notes.</p>
        </div>
      </header>

      <section class="staff-grid" id="review-stats"></section>

      <div class="filter-row" id="review-filters">
        <button class="active" data-filter="all">All</button>
        <button data-filter="pending">Pending</button>
        <button data-filter="approved">Approved</button>
        <button data-filter="rejected">Rejected</button>
      </div>

      <section class="review-list" id="review-list">
        <div class="staff-card loading-card">Loading review queue…</div>
      </section>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="/supabaseClient.js"></script>
  <script src="/access-control.js"></script>
  <script src="/review.js"></script>
</body>
</html>
