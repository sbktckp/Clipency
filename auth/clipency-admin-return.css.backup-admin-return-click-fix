.cx-admin-return-link {
  width: calc(100% - 32px);
  min-height: 50px;
  margin: auto 16px 16px;
  padding: 0 16px;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 12px;
  border: 1px solid rgba(167,139,250,0.18);
  border-radius: 18px;
  background: rgba(124,58,237,0.14);
  color: white;
  text-decoration: none;
  font-size: 15px;
  font-weight: 900;
}

.cx-admin-return-link span {
  width: 28px;
  height: 28px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  background: rgba(167,139,250,0.20);
  color: #c4b5fd;
}
