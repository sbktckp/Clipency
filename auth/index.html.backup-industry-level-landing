          </div>
          <div class="metric-tile">
            <strong data-count="24">0</strong>
            <span>Submission-led visibility</span>
          </div>
        </div>
      </div>

      <div class="hero-product reveal delay-1">
        <div class="glass-panel product-panel">
          <div class="panel-top">
            <div class="window-dots">
              <span></span><span></span><span></span>
            </div>
            <div class="live-badge">Live system</div>
          </div>

          <div class="campaign-preview">
            <div>
              <span class="panel-kicker">Campaign command</span>
              <h2>Distribution Engine</h2>
              <p>Briefs, creators, proof and payouts connected into one campaign layer.</p>
            </div>

            <div class="campaign-orbit">
              <div class="orbit-core">C</div>
              <span class="orbit-dot dot-one"></span>
              <span class="orbit-dot dot-two"></span>
              <span class="orbit-dot dot-three"></span>
